// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  NEGOCIO
  VECINO
}

enum Localidad {
  NEPTUNIA
  PINAMAR
  SALINAS
  MARINDIA
  EL_FORTIN
  VILLA_ARGENTINA
  ATLANTIDA
  LAS_TOSCAS
  PARQUE_DEL_PLATA
  LAS_VEGAS
  LAS_VEGAS_NORTE
  LA_FLORESTA
  ESTACION_FLORESTA
  COSTA_AZUL
  BELLO_HORIZONTE
  GUAZUVIRA_NUEVO
  GUAZUVIRA_VIEJO
  SAN_LUIS
  LOS_TITANES
  LA_TUNA
  ARAMINDA
  SANTA_LUCIA_DEL_ESTE
  BIARRITZ
  CUCHILLA_ALTA
  EL_GALEON
  SANTA_ANA
  BALNEARIO_ARGENTINO
  JAUREGUIBERRY
}

enum Categoria {
  MERCADO
  PATITAS
  CULTURA
  SERVICIOS
  TRABAJO
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  nombre      String
  telefono    String?
  localidad   Localidad
  role        Role     @default(VECINO)
  fotoUrl     String?
  profile     Profile? // Solo si es Negocio/Org
  posts       Post[]
}

model Profile {
  id         String  @id @default(uuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id])
  googleMaps String?
  instagram  String?
  facebook   String?
  tiktok     String?
}

model Post {
  id           String   @id @default(uuid())
  authorId     String
  author       User     @relation(fields: [authorId], references: [id])
  titulo       String
  fecha        String
  hora         String
  contenido    String
  localidad   Localidad
  categoria    String   // Ej: "MERCADO"
  subCategoria String   // Ej: "GRATIFERIA"
  fotos        String[] 
  createdAt    DateTime @default(now())
}